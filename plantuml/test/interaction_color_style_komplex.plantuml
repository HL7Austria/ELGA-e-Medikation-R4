@startuml

title Color Style Test - Komplexe Darstellung ohne Boxen

'skinparam actorStyle awesome

skinparam borderColor #000000
skinparam backgroundColor #f5f5f5
skinparam shadowing false
skinparam roundCorner 10
skinparam defaultFontName "Arial"
'skinparam defaultFontSize 14
skinparam defaultFontColor #000000
skinparam HyperlinkColor #0000EE
skinparam HyperlinkUnderline false
skinparam BoxPadding 20
skinparam BoxBorderColor #555555

skinparam note {
  BackgroundColor #e0e5f0-#d1d9e6
  BorderColor #8b95a5
  BorderThickness 1
  RoundCorner 0
  Padding 6
  FontColor #111827
  Shadowing false
}

skinparam sequence {
  ParticipantBorderColor #555555
  ParticipantBackgroundColor #ffffff
  ParticipantFontColor #000000
  ParticipantFontSize 14
  ParticipantPadding 20
  ArrowColor #111827
  ArrowThickness 1
  ArrowFontColor #000000
  ArrowFontSize 13
  GroupBorderColor #111827
  GroupBackgroundColor #eef2ff
  GroupBorderThickness 2
}

!define COLOR_GDA_1    #15608280
!define COLOR_GDA_2    #96607D80
!define COLOR_PATIENT  #196B2480
!define COLOR_APO      #0F9ED590
!define COLOR_EMED_FA  #e97232bd
!define COLOR_E_REZEPT #cd3732a9

!define COLOR_OK       #0F9ED525
!define COLOR_ERROR    #E9713235


actor GDA_1 as "GDA 1" COLOR_GDA_1
actor GDA_2 as "GDA 2" COLOR_GDA_2
participant eMed_FA as "e-Med FA" COLOR_EMED_FA
actor e_Rezept as "e-Rezept" COLOR_E_REZEPT
actor GDA_Apo as "Apotheke" COLOR_APO
actor Patient as "Patient" COLOR_PATIENT

autonumber

== Medikationsplan abrufen ==

activate GDA_1 COLOR_GDA_1
ref over GDA_1, eMed_FA : [[interactions.html#sequenzdiagramm-plan-read Plan-Read]]

note over GDA_1
GDA erhält Medikationsplan 
(Auslieferungs-Collection-Bundle)
end note

== <i>Geplante Abgaben</i> vorbereiten und schreiben ==

GDA_1 -> eMed_FA: POST $groupidentifier-create​ 

note over GDA_1
e-Med GroupIdentifier für "Rezeptklammer"
anfordern
end note

activate eMed_FA COLOR_EMED_FA
activate GDA_2 COLOR_GDA_2
eMed_FA -> GDA_2: Test
eMed_FA --> GDA_2: Test
deactivate GDA_2

activate Apotheke COLOR_APO
eMed_FA -> Apotheke: Test
eMed_FA --> Apotheke: Test
deactivate Apotheke

activate Patient COLOR_PATIENT
eMed_FA -> Patient: Test
eMed_FA --> Patient: Test
deactivate Patient
deactivate eMed_FA

note over GDA_1
Erstellte <i>Geplante Abgaben</i> referenzieren 
zugehörige Medikationsplaneinträge und
enthalten e-Med GroupIdentifier
end note

par Erstellung e-Rezept

  GDA_1 -> e_Rezept: Trigger e-Rezept erstellen
  activate e_Rezept COLOR_E_REZEPT
  note over GDA_1
  Erstellung e-Rezept auslösen
  end note

  alt COLOR_OK e-Rezept erstellt
    e_Rezept --> GDA_1: OK
    
  else COLOR_ERROR e-Rezept Fehler
    e_Rezept --> GDA_1: Fehler 
    deactivate e_Rezept
    GDA_1 -> eMed_FA: POST $prescription-discard​
    
    note over GDA_1
    Siehe Use Case "<i>Geplante Abgabe</i> verwerfen"
    end note
  end

else gleichzeitige Erstellung <i>Geplante Abgabe</i>

  GDA_1 -> eMed_FA: POST $prescription-write
  activate eMed_FA COLOR_EMED_FA
  note over GDA_1
  Transaction Bundle mit Geplanten
  Abgaben an Fachanwendung übermitteln
  end note
  
  alt COLOR_OK <i>Geplante Abgabe</i> erstellt
    eMed_FA --> GDA_1: OK

    note over eMed_FA
      Geplante Abgabe 1 + 2 gespeichert
    end note

  else COLOR_ERROR <i>Geplante Abgabe</i> Fehler
    eMed_FA --> GDA_1: Fehler

    alt COLOR_OK Geplante Abgabe erneut übermitteln
      GDA_1 -> eMed_FA: POST $prescription-write

    else COLOR_ERROR Fehler nicht behebbar
      deactivate eMed_FA
      GDA_1 -> e_Rezept: e-Rezept von e-Med GroupIdentifier entkoppeln
      deactivate GDA_1 

    end
  end
end

@enduml